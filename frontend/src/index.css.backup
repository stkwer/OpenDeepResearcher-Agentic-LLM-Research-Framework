@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
    body {
        @apply bg-gradient-to-br from-slate-950 via-slate-900 to-slate-950 text-slate-100 font-sans antialiased;
        margin: 0;
        padding: 0;
        min-height: 100vh;
    }

    #root {
        min-height: 100vh;
    }
  :root {
        --background: 0 0% 100%;
        --foreground: 0 0% 3.9%;
        --card: 0 0% 100%;
        --card-foreground: 0 0% 3.9%;
        --popover: 0 0% 100%;
        --popover-foreground: 0 0% 3.9%;
        --primary: 0 0% 9%;
        --primary-foreground: 0 0% 98%;
        --secondary: 0 0% 96.1%;
        --secondary-foreground: 0 0% 9%;
        --muted: 0 0% 96.1%;
        --muted-foreground: 0 0% 45.1%;
        --accent: 0 0% 96.1%;
        --accent-foreground: 0 0% 9%;
        --destructive: 0 84.2% 60.2%;
        --destructive-foreground: 0 0% 98%;
        --border: 0 0% 89.8%;
        --input: 0 0% 89.8%;
        --ring: 0 0% 3.9%;
        --chart-1: 12 76% 61%;
        --chart-2: 173 58% 39%;
        --chart-3: 197 37% 24%;
        --chart-4: 43 74% 66%;
        --chart-5: 27 87% 67%;
        --radius: 0.5rem;
    }
  .dark {
        --background: 0 0% 3.9%;
        --foreground: 0 0% 98%;
        --card: 0 0% 3.9%;
        --card-foreground: 0 0% 98%;
        --popover: 0 0% 3.9%;
        --popover-foreground: 0 0% 98%;
        --primary: 0 0% 98%;
        --primary-foreground: 0 0% 9%;
        --secondary: 0 0% 14.9%;
        --secondary-foreground: 0 0% 98%;
        --muted: 0 0% 14.9%;
        --muted-foreground: 0 0% 63.9%;
        --accent: 0 0% 14.9%;
        --accent-foreground: 0 0% 98%;
        --destructive: 0 62.8% 30.6%;
        --destructive-foreground: 0 0% 98%;
        --border: 0 0% 14.9%;
        --input: 0 0% 14.9%;
        --ring: 0 0% 83.1%;
        --chart-1: 220 70% 50%;
        --chart-2: 160 60% 45%;
        --chart-3: 30 80% 55%;
        --chart-4: 280 65% 60%;
        --chart-5: 340 75% 55%;
    }
}

@layer components {

    /* Custom scrollbar - Dark theme */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }

    .custom-scrollbar::-webkit-scrollbar-track {
        @apply bg-slate-900;
        border-radius: 4px;
    }

    .custom-scrollbar::-webkit-scrollbar-thumb {
        @apply bg-slate-700 hover:bg-slate-600;
        border-radius: 4px;
    }

    /* Glass effect - Dark */
    .glass {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(148, 163, 184, 0.1);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);
    }

    /* Message bubble styles */
    .message-bubble {
        @apply rounded-2xl px-5 py-4 max-w-3xl shadow-lg;
    }

    .message-user {
        @apply bg-gradient-to-r from-teal-600 to-teal-500 text-white ml-auto;
    }

    .message-assistant {
        @apply glass text-slate-100 mr-auto border border-slate-700;
    }

    /* Input styles */
    .chat-input {
        @apply w-full bg-slate-800 border border-slate-700 rounded-xl px-4 py-3 text-slate-100 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent resize-none custom-scrollbar transition-all duration-200;
    }

    /* Button styles */
    .btn-primary {
        @apply bg-gradient-to-r from-teal-600 to-teal-500 hover:from-teal-700 hover:to-teal-600 text-white font-medium px-6 py-2.5 rounded-xl transition-all duration-200 shadow-md hover:shadow-lg hover:shadow-teal-500/50 hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100;
    }

    .btn-secondary {
        @apply bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium px-4 py-2 rounded-lg transition-all duration-200 border border-slate-700 hover:border-slate-600 hover:scale-105 active:scale-95 shadow-sm;
    }

    .sidebar-item {
        @apply px-3 py-2 rounded-md text-slate-400 hover:bg-slate-800/70 transition-colors duration-150 cursor-pointer text-sm flex items-center gap-2;
    }

    .sidebar-item-active {
        @apply bg-slate-800/90 text-slate-200;
    }

    /* Ambient Gradient Glow Effect */
    .ambient-glow-container {
        position: relative;
    }

    .ambient-glow-container::before {
        content: '';
        position: absolute;
        inset: -3px;
        border-radius: 0.75rem;
        /* Match rounded-xl */
        padding: 3px;
        background: linear-gradient(90deg,
                rgba(251, 146, 60, 1) 0%,
                rgba(249, 115, 22, 1) 20%,
                rgba(236, 72, 153, 1) 40%,
                rgba(168, 85, 247, 1) 60%,
                rgba(59, 130, 246, 1) 80%,
                rgba(14, 165, 233, 1) 100%);
        -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
        -webkit-mask-composite: xor;
        mask-composite: exclude;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    .ambient-glow-container.active::before {
        opacity: 1;
    }

    .ambient-glow-container::after {
        content: '';
        position: absolute;
        inset: -60px;
        border-radius: 0.75rem;
        /* Match rounded-xl */
        background: radial-gradient(ellipse at 15% 50%,
                rgba(251, 146, 60, 0.6) 0%,
                rgba(249, 115, 22, 0.5) 15%,
                rgba(236, 72, 153, 0.4) 30%,
                transparent 60%),
            radial-gradient(ellipse at 85% 50%,
                rgba(59, 130, 246, 0.6) 0%,
                rgba(139, 92, 246, 0.5) 15%,
                rgba(168, 85, 247, 0.4) 30%,
                transparent 60%),
            radial-gradient(ellipse at 50% 50%,
                rgba(236, 72, 153, 0.3) 0%,
                transparent 50%);
        filter: blur(50px);
        opacity: 0;
        transition: opacity 0.4s ease;
        z-index: -1;
        pointer-events: none;
    }

    .ambient-glow-container.active::after {
        opacity: 1;
    }

    /* Animated RGB glow */
    @keyframes rgb-glow {
        0% {
            filter: hue-rotate(0deg) blur(50px);
        }

        100% {
            filter: hue-rotate(360deg) blur(50px);
        }
    }

    .ambient-glow-container.animated::after {
        animation: rgb-glow 6s linear infinite;
    }
}

@layer utilities {
    .text-gradient {
        @apply bg-gradient-to-r from-teal-400 to-purple-500 bg-clip-text text-transparent;
    }

    .glow-text {
        text-shadow: 0 0 20px rgba(20, 184, 166, 0.5);
    }
}



@layer base {
  * {
    @apply border-border;
    }
  body {
    @apply bg-background text-foreground;
    }
}